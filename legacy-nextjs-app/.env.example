# Environment Configuration Template
# Copy this file to .env.local for development

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...

# Server-side Supabase (keep secret)
DATABASE_URL=postgresql://postgres:password@your-project-ref.supabase.co:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...

# =============================================================================
# AUTHENTICATION (CLERK)
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# =============================================================================
# AI SERVICES (REPLICATE)
# =============================================================================
REPLICATE_API_TOKEN=r8_...
WEBHOOK_SECRET=your_webhook_secret_for_replicate

# =============================================================================
# AI SERVICES (FAL - Fast AI Labs)
# =============================================================================
FAL_API_KEY=fal_...
FAL_WEBHOOK_SECRET=your_webhook_secret_for_fal

# FAL Model Configuration
FAL_BASE_IMAGE_MODEL=fal-ai/flux/schnell
FAL_PREMIUM_IMAGE_MODEL=fal-ai/flux/dev
FAL_VIDEO_MODEL=fal-ai/runway-gen3/turbo/image-to-video
FAL_UPSCALE_MODEL=fal-ai/real-esrgan
FAL_FACE_MODEL=fal-ai/face-swap

# =============================================================================
# PAYMENTS (STRIPE)
# =============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Product/Price IDs
STRIPE_PRO_PRICE_ID=price_...  # Pro plan price ID ($9/month)
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...  # Same as above, for client-side use

# =============================================================================
# MONITORING & ALERTS
# =============================================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# =============================================================================
# CACHING (OPTIONAL - UPSTASH REDIS)
# =============================================================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# =============================================================================
# EMAIL (RESEND)
# =============================================================================
RESEND_API_KEY=re_...

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================
# Enable verbose logging in development
DEBUG=klipcam:*

# Skip email verification in development
SKIP_EMAIL_VERIFICATION=true

# Use local file storage instead of Supabase in development
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=./uploads

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_LORA_TRAINING=true
ENABLE_VIDEO_GENERATION=true
ENABLE_SPIDER_EFFECTS=true
MAX_CONCURRENT_JOBS=2

# =============================================================================
# SECURITY
# =============================================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-32-character-random-string
JWT_SECRET=your-jwt-secret

# Security Headers
CSP_DIRECTIVES=default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' *.clerk.com *.stripe.com; style-src 'self' 'unsafe-inline' *.googleapis.com; img-src 'self' data: https:; connect-src 'self' *.clerk.com *.supabase.co *.stripe.com *.replicate.com; frame-src 'self' *.stripe.com;

# CORS settings
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# Rate Limiting (per minute/hour)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_BURST_MAX_REQUESTS=100

# Demo mode prevention in production
PREVENT_DEMO_MODE=true
PRODUCTION_DOMAIN=klipcam.com

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================
# Database connection pool settings
DATABASE_MAX_CONNECTIONS=10
DATABASE_IDLE_TIMEOUT=30000

# File upload limits (in bytes)
MAX_FILE_SIZE=10485760  # 10MB
MAX_FILES_PER_USER=1000

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# =============================================================================
# BUSINESS LOGIC
# =============================================================================
# Credit costs (can be overridden per environment)
CREDIT_COST_BASE_IMAGE=1
CREDIT_COST_PREMIUM_IMAGE=4
CREDIT_COST_IMAGE_UPSCALE=4
CREDIT_COST_BASE_VIDEO=18
CREDIT_COST_SPIDER_VIDEO=25
CREDIT_COST_LORA_TRAINING=50

# Subscription settings
SUBSCRIPTION_CREDITS_PER_MONTH=900
TRIAL_CREDITS=10
TRIAL_DURATION_DAYS=7

# =============================================================================
# AI MODEL CONFIGURATION
# =============================================================================
# AI Provider Selection (replicate, fal, or both)
AI_PROVIDER=fal  # Options: replicate, fal, hybrid
FALLBACK_PROVIDER=replicate  # Fallback if primary provider fails

# Replicate models
REPLICATE_BASE_IMAGE_MODEL=qwen/qwen-image
REPLICATE_PREMIUM_IMAGE_MODEL=black-forest-labs/flux-1-dev
REPLICATE_UPSCALE_MODEL=nightmareai/real-esrgan
REPLICATE_BASE_VIDEO_MODEL=wan-video/wan-2.2-t2v-fast
REPLICATE_SPIDER_VIDEO_MODEL=minimax/hailuo-2

# FAL models (faster inference)
FAL_BASE_IMAGE_MODEL=fal-ai/flux/schnell
FAL_PREMIUM_IMAGE_MODEL=fal-ai/flux/dev
FAL_VIDEO_MODEL=fal-ai/runway-gen3/turbo/image-to-video
FAL_UPSCALE_MODEL=fal-ai/real-esrgan
FAL_FACE_MODEL=fal-ai/face-swap

# Model performance preferences
PREFER_SPEED_OVER_QUALITY=false  # Use faster models when true
MAX_INFERENCE_TIME_SECONDS=300   # Timeout for model inference

# Default generation parameters
DEFAULT_IMAGE_WIDTH=768
DEFAULT_IMAGE_HEIGHT=768
DEFAULT_VIDEO_DURATION=3
DEFAULT_INFERENCE_STEPS=20
DEFAULT_GUIDANCE_SCALE=7.5

# =============================================================================
# ASSET MANAGEMENT
# =============================================================================
# Asset retention policies
TRIAL_ASSET_RETENTION_DAYS=30
PAID_ASSET_RETENTION_DAYS=365
MAX_STORAGE_PER_USER_GB=10

# Image processing
WATERMARK_TRIAL_ASSETS=true
WATERMARK_TEXT="KlipCam Trial"
COMPRESSION_QUALITY=85
SUPPORTED_FORMATS=jpg,png,webp

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=./logs/app.log
LOG_MAX_FILES=10
LOG_MAX_SIZE=10m

# =============================================================================
# DEVELOPMENT HELPERS
# =============================================================================
# Mock external services in development
MOCK_REPLICATE_API=false
MOCK_STRIPE_WEBHOOKS=false
MOCK_EMAIL_SENDING=true

# Seed database with test data
SEED_DATABASE=false
SEED_USER_COUNT=10
SEED_JOB_COUNT=100