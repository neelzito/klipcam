# Production Environment Configuration
# Copy this file to .env.production for production deployment

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_APP_URL=https://klipcam.com

# =============================================================================
# SUPABASE CONFIGURATION (Production)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_production_anon_key

# Server-side Supabase (Production - keep secret)
DATABASE_URL=postgresql://postgres:password@your-production-project.supabase.co:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key

# =============================================================================
# AUTHENTICATION (CLERK - Production)
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_production_key
CLERK_SECRET_KEY=sk_live_your_production_secret
CLERK_WEBHOOK_SECRET=whsec_your_production_webhook_secret

# =============================================================================
# AI SERVICES (REPLICATE - Production)
# =============================================================================
REPLICATE_API_TOKEN=r8_your_production_token
WEBHOOK_SECRET=your_production_webhook_secret_32_chars

# =============================================================================
# PAYMENTS (STRIPE - Production)
# =============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_production_key
STRIPE_SECRET_KEY=sk_live_your_production_secret
STRIPE_WEBHOOK_SECRET=whsec_your_production_webhook_secret
STRIPE_PRICE_ID=price_your_production_price_id

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Error Tracking (Sentry)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
SENTRY_ENVIRONMENT=production

# Performance Monitoring (DataDog/New Relic)
DD_API_KEY=your_datadog_api_key
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key

# Uptime Monitoring
UPTIME_KUMA_WEBHOOK=https://your-uptime-monitoring-webhook

# =============================================================================
# CACHING (UPSTASH REDIS - Production)
# =============================================================================
UPSTASH_REDIS_REST_URL=https://your-production-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_production_redis_token

# =============================================================================
# EMAIL (RESEND - Production)
# =============================================================================
RESEND_API_KEY=re_your_production_key
FROM_EMAIL=noreply@klipcam.com

# =============================================================================
# SECURITY (Production)
# =============================================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_production_32_character_random_string
JWT_SECRET=your_production_jwt_secret

# CORS settings for production
ALLOWED_ORIGINS=https://klipcam.com,https://www.klipcam.com

# Content Security Policy
CSP_REPORT_URI=https://your-csp-report-endpoint.com/report

# =============================================================================
# PERFORMANCE & SCALING
# =============================================================================
# Database connection pool settings (production optimized)
DATABASE_MAX_CONNECTIONS=20
DATABASE_IDLE_TIMEOUT=30000

# File upload limits (production)
MAX_FILE_SIZE=10485760  # 10MB
MAX_FILES_PER_USER=10000

# Rate limiting (production)
RATE_LIMIT_REQUESTS_PER_MINUTE=30
RATE_LIMIT_REQUESTS_PER_HOUR=500
RATE_LIMIT_CONCURRENT_JOBS=2

# =============================================================================
# BUSINESS LOGIC (Production)
# =============================================================================
# Credit costs (production rates)
CREDIT_COST_BASE_IMAGE=1
CREDIT_COST_PREMIUM_IMAGE=4
CREDIT_COST_IMAGE_UPSCALE=4
CREDIT_COST_BASE_VIDEO=18
CREDIT_COST_SPIDER_VIDEO=25

# Subscription settings (production)
SUBSCRIPTION_CREDITS_PER_MONTH=900
TRIAL_CREDITS=10
TRIAL_DURATION_DAYS=7

# =============================================================================
# AI MODEL CONFIGURATION (Production)
# =============================================================================
# Production model versions (use specific versions for stability)
BASE_IMAGE_MODEL=qwen/qwen-image:version_hash
PREMIUM_IMAGE_MODEL=black-forest-labs/flux-1-dev:version_hash
UPSCALE_MODEL=nightmareai/real-esrgan:version_hash
BASE_VIDEO_MODEL=wan-video/wan-2.2-t2v-fast:version_hash
SPIDER_VIDEO_MODEL=minimax/hailuo-2:version_hash

# Model fallbacks (production)
ENABLE_MODEL_FALLBACKS=true
MAX_RETRY_ATTEMPTS=3
FALLBACK_TIMEOUT_MS=30000

# =============================================================================
# ASSET MANAGEMENT (Production)
# =============================================================================
# Asset retention policies (production)
TRIAL_ASSET_RETENTION_DAYS=30
PAID_ASSET_RETENTION_DAYS=365
MAX_STORAGE_PER_USER_GB=10

# CDN Configuration
CDN_URL=https://cdn.klipcam.com
ENABLE_CDN_ASSETS=true

# Image processing (production optimized)
WATERMARK_TRIAL_ASSETS=true
WATERMARK_TEXT="KlipCam"
COMPRESSION_QUALITY=85
SUPPORTED_FORMATS=jpg,png,webp

# =============================================================================
# LOGGING (Production)
# =============================================================================
LOG_LEVEL=warn
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_FILE_PATH=/var/log/klipcam/app.log
LOG_MAX_FILES=30
LOG_MAX_SIZE=100m

# Structured logging
ENABLE_REQUEST_LOGGING=true
ENABLE_PERFORMANCE_LOGGING=true
ENABLE_ERROR_LOGGING=true

# =============================================================================
# FEATURE FLAGS (Production)
# =============================================================================
# Feature toggles for gradual rollout
ENABLE_VIDEO_GENERATION=true
ENABLE_SPIDER_EFFECTS=true
ENABLE_I2I_GENERATION=true
ENABLE_I2V_GENERATION=true

# A/B Testing
ENABLE_AB_TESTING=true
AB_TEST_NEW_PRESET_UI=50  # 50% of users see new UI

# =============================================================================
# DEPLOYMENT & INFRASTRUCTURE
# =============================================================================
# Vercel specific
VERCEL_URL=klipcam.com
VERCEL_ENV=production

# Build optimization
NEXT_TELEMETRY_DISABLED=1
ANALYZE_BUNDLE=false

# Health check endpoints
HEALTH_CHECK_PATH=/api/health
METRICS_PATH=/api/metrics

# =============================================================================
# EXTERNAL INTEGRATIONS
# =============================================================================
# Social media APIs (for sharing features)
INSTAGRAM_API_KEY=your_instagram_api_key
TIKTOK_API_KEY=your_tiktok_api_key

# Analytics
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
MIXPANEL_TOKEN=your_mixpanel_token
AMPLITUDE_API_KEY=your_amplitude_key

# Customer support
INTERCOM_APP_ID=your_intercom_app_id
ZENDESK_SUBDOMAIN=your_zendesk_subdomain